# Copy this file to .env and fill in your API keys.
# The agent loads keys via python-dotenv from .env automatically.

# DeepInfra (for deepinfra:* open-source models)
DEEPINFRA_API_KEY=your-deepinfra-key-here

# Anthropic (for anthropic:* models)
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenRouter (for openrouter:* models — GPT, Gemini, GLM, Kimi, MiniMax, etc.)
OPENROUTER_API_KEY=your-openrouter-key-here

# SpireHDL compilation timeout in seconds (default when not set: 60)
SPIREHDL_TIMEOUT=600
