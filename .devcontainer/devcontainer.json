// .devcontainer/devcontainer.json
//
// Two options for the image:
//
// Option A (default): Pre-built image.
//   Build once with `bash .devcontainer/build_image.sh`, then reuse.
//
// Option B: Build from Dockerfile on container creation.
//   Replace "image" with:
//     "build": { "dockerfile": "Dockerfile", "context": ".." }
//   Slow on first open (the base image compiles OpenROAD from source, ~1-2h).
//
{
    "name": "rtl_scout",
    "initializeCommand": "bash -c 'cd ${localWorkspaceFolder} && bash .devcontainer/setup_workspace.sh && bash .devcontainer/build_image.sh'",
    "image": "rtlscout:latest",
    // Pin the workspace path to /workspaces/rtl_scout regardless of the cloned folder's name, so the
    // VS Code flow matches start_container.sh / entrypoint.sh and the absolute paths used in core/.
    "workspaceFolder": "/workspaces/rtl_scout",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/rtl_scout,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "bash /workspaces/rtl_scout/.devcontainer/post_create.sh"
    // gpu support
    //"runArgs": [ "--gpus", "all" ]
}
